{
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "on-scroll-up": "workspace+1",
    "on-scroll-down": "workspace-1"
  },
  "cpu": {
    "interval": 2,
    "format": "ΎΜδ  {usage}%",
    "tooltip": false
  },
  "memory": {
    "interval": 2,
    "format": "Ό┐Ζ  {used:0.1f}G/{total:0.1f}G",
    "tooltip": false
  },
  "network": {
    "interval": 5,
    "format": "{ifname}",
    "format-wifi": "ΎΘτ  {signalStrength}%",
    "format-ethernet": "≤░ΙΑ  {ipaddr}",
    "format-disconnected": "≤░Νβ  Disconnected",
    "tooltip": false
  },
  "network#speed": {
    "interval": 2,
    "format": "ΎΑβ  {bandwidthUpBytes} ΎΓΥ  {bandwidthDownBytes}",
    "max-length": 26
  },
  "clock": {
    "interval": 60,
    "format": "ΎΑΩ  {:%a %d - %H:%M}",
    "tooltip": false
  },
  "battery": {
    "interval": 5,
    "format": "{capacity}% {icon}",
    "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
    "format-plugged": "ΎΘο {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "tooltip": false
  },
  "pulseaudio#output": {
    "format": "ΎΑρ  {volume}%",
    "format-muted": "ΎΣο  Muted",
    "on-click": "pavucontrol",
    "on-click-right": "amixer sset Master toggle"
  },
  "pulseaudio#input": {
    "format": "{format_source}",
    "format-source": "ΎΕ░ On",
    "format-source-muted": "ΎΕ▒  Muted",
    "on-click": "pavucontrol",
    "on-click-right": "amixer sset Capture toggle",
    "tooltip": false
  },
  "backlight": {
    "format": "≤░δρ {percent}%",
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "disk": {
    "interval": 15,
    "format": "≤░ΜΛ {free}",
    "path": "/"
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤▒Ζτ ",
      "none": "ΎΓλ ",
      "dnd-notification": "≤░Γδ ",
      "dnd-none": "≤░ςΣ ",
      "inhibited-notification": "≤▒Ζτ ",
      "inhibited-none": "ΎΓλ ",
      "dnd-inhibited-notification": "≤░Γδ ",
      "dnd-inhibited-none": "ΎΘ╖ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "tray": {
    "spacing": 10
  }
}
